    <mass value="19.9033372562808"/>
    <inertia ixx="0.720932" iyy="0.120784" izz="0.676639" ixy="0.003917" iyz="0.050773" ixz="-0.017565"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://Rice_description/meshes/leg_bl.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="Rice_silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://Rice_description/meshes/leg_bl.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="${prefix}leg_fr">
  <inertial>
    <origin xyz="0.020209424438183965 -0.4348060753188833 0.058184114296319" rpy="0 0 0"/>
    <mass value="19.90333719348541"/>
    <inertia ixx="0.720932" iyy="0.120784" izz="0.676639" ixy="-0.003917" iyz="-0.050773" ixz="-0.017565"/>
