<link name="${prefix}wheel_bl">
  <inertial>
    <origin xyz="0.0020000000000000018 0.46499999999999997 1.0899999999999923" rpy="0 0 0"/>
    <mass value="65.80472593736363"/>
    <inertia ixx="1.584128" iyy="0.836383" izz="0.836383" ixy="0.0" iyz="0.0" ixz="0.0"/>
