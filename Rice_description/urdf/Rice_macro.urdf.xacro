<joint name="${prefix}Revolute 9" type="continuous">
  <origin xyz="0.77 0.465 1.09" rpy="0.0 -0.0 0.0"/>
  <parent link="${prefix}base_link"/>
  <child link="${prefix}leg_br"/>
  <axis xyz="0.0 -1.0 0.0"/>
</joint>

<joint name="${prefix}Revolute 10" type="continuous">
  <origin xyz="0.0 0.465 1.09" rpy="0.0 -0.0 0.0"/>
  <parent link="${prefix}base_link"/>
  <child link="${prefix}leg_bl"/>
  <axis xyz="0.0 -1.0 0.0"/>
</joint>

<joint name="${prefix}Revolute 11" type="continuous">
  <origin xyz="0.77 0.465 0.0" rpy="0.0 -0.0 0.0"/>
  <parent link="${prefix}base_link"/>
  <child link="${prefix}leg_fr"/>
  <axis xyz="0.0 -1.0 0.0"/>
</joint>

<joint name="${prefix}Revolute 12" type="continuous">
  <origin xyz="0.0 0.465 -0.0" rpy="0.0 -0.0 0.0"/>
  <parent link="${prefix}base_link"/>
  <child link="${prefix}leg_fl"/>
  <axis xyz="0.0 -1.0 0.0"/>
</joint>

<joint name="${prefix}Revolute 13" type="continuous">
  <origin xyz="0.093 -0.67 0.0" rpy="0.0 -0.0 0.0"/>
  <parent link="${prefix}leg_br"/>
  <child link="${prefix}wheel_br"/>
  <axis xyz="1.0 0.0 0.0"/>
</joint>

<joint name="${prefix}Revolute 14" type="continuous">
