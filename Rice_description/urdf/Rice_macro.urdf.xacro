    <origin xyz="-0.020233756052453953 -0.43473344154932647 0.05820262908150501" rpy="0 0 0"/>
    <mass value="19.897003188386865"/>
    <inertia ixx="0.72058" iyy="0.120724" izz="0.676271" ixy="0.003807" iyz="-0.050689" ixz="0.017537"/>
