<?xml version="1.0" ?>
<robot name="Rice" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:macro name="Rice" params="prefix load_meta:=true">

<xacro:if value="${load_meta}">
  <xacro:include filename="$(find Rice_description)/urdf/materials.xacro" />
  <xacro:include filename="$(find Rice_description)/urdf/Rice.trans" />
  <xacro:include filename="$(find Rice_description)/urdf/Rice.gazebo" />
</xacro:if>

<link name="${prefix}base_link"/>

<link name="${prefix}leg_br">
  <inertial>
    <origin xyz="0.02067495895251803 -0.42960566115027676 -0.059489197402857075" rpy="0 0 0"/>
    <mass value="19.428196282242897"/>
    <inertia ixx="0.69198" iyy="0.118365" izz="0.64895" ixy="-0.001759" iyz="0.04479" ixz="0.016967"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://Rice_description/meshes/leg_br.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="Rice_silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://Rice_description/meshes/leg_br.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="${prefix}leg_bl">
